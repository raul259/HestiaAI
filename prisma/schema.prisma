generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Property {
  id                   String         @id @default(cuid())
  hostId               String
  name                 String
  address              String
  description          String?
  wifiName             String?
  wifiPassword         String?
  checkoutInstructions String?
  wasteInstructions    String?
  emergencyContact     String?
  hostName             String
  hostEmail            String
  accessCode           String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  appliances           Appliance[]
  incidents            Incident[]
  conversations        Conversation[]
}

model Appliance {
  id         String        @id @default(cuid())
  propertyId String
  name       String
  model      String?
  category   String
  manual     String
  location   String?
  createdAt  DateTime      @default(now())
  property   Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  chunks     ManualChunk[]
}

model ManualChunk {
  id          String    @id @default(cuid())
  applianceId String
  chunkIndex  Int
  chunkText   String
  embedding   String    // JSON array de floats (text-embedding-004, 768 dims)
  appliance   Appliance @relation(fields: [applianceId], references: [id], onDelete: Cascade)
}

model Incident {
  id          String    @id @default(cuid())
  propertyId  String
  title       String
  description String
  category    String
  status      String    @default("open")
  priority    String    @default("medium")
  guestName   String?
  guestEmail  String?
  scheduledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Conversation {
  id         String   @id @default(cuid())
  propertyId String
  sessionId  String
  messages   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}
